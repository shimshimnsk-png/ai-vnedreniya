# Пример переменных окружения
# Эти переменные НЕ коммитятся в git (см. .gitignore).
# Для продакшена их задают в Netlify → Site settings → Environment variables.
# Локально: скопируй этот файл в .env и заполни реальными значениями для netlify dev.

# Токен Telegram-бота (получить у @BotFather)
TG_BOT_TOKEN=your_telegram_bot_token_here

# ID чата, куда бот шлёт заявки (узнать у @userinfobot)
TG_CHAT_ID=your_telegram_chat_id_here
